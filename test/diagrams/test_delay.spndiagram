{
  "version": "1.0",
  "metadata": {
    "name": "delay_crossfade_test",
    "author": "",
    "description": "Tests mathematical routing loops, dual signal merging, and constant parameter folding."
  },
  "blocks": [
    {
      "id": "input-1",
      "type": "input.adc",
      "position": { "x": 0, "y": 0 },
      "parameters": { "gain": 1, "adcNumber": 0 }
    },
    {
      "id": "delay-1",
      "type": "effects.delay.simple",
      "position": { "x": 200, "y": 0 },
      "parameters": {
        "delayTime": 250,
        "feedback": 0.5,
        "mix": 1.0
      }
    },
    {
      "id": "crossfade-1",
      "type": "math.crossfade",
      "position": { "x": 400, "y": 0 },
      "parameters": {
        "mix": 0.25
      }
    },
    {
      "id": "output-1",
      "type": "output.dac",
      "position": { "x": 600, "y": 0 },
      "parameters": { "dacNumber": 0 }
    }
  ],
  "connections": [
    { "source": "input-1", "sourcePort": "out", "target": "delay-1", "targetPort": "audio_input" },
    
    { "source": "input-1", "sourcePort": "out", "target": "crossfade-1", "targetPort": "input1" },
    { "source": "delay-1", "sourcePort": "audio_output", "target": "crossfade-1", "targetPort": "input2" },
    
    { "source": "crossfade-1", "sourcePort": "output", "target": "output-1", "targetPort": "in" }
  ]
}
