;================================================================================
; test_filters_all
; Tests all filter types (1P LP/HP, Shelving LP/HP, 2P SVF).
;  Block Diagram Editor (https://www.audiofab.com/)
;================================================================================

; Block Declarations
;--------------------------------------------------------------------------------
equ	cv_b2_f_cv	0.374164
;	Resonance bounds: Calculate Damping (d = 1/Q)
equ	d_target (1.414427)

; Initialization
;--------------------------------------------------------------------------------
; Register Aliases
; OPTIMIZED OUT - equ	adc_out	REG0 (Unused register)
equ	lpf_1p_lpf1	REG1
; OPTIMIZED OUT - equ	hpf_1p_output	REG2 (Unused register)
equ	svf_2p_lp	REG3
; OPTIMIZED OUT - equ	lpf_1p_local_output	REG4 (Unused register)
equ	hpf_1p_local_lpf1	REG5
; OPTIMIZED OUT - equ	svf_2p_bp	REG6 (Unused register)
; OPTIMIZED OUT - equ	svf_2p_hp	REG7 (Unused register)
; OPTIMIZED OUT - equ	svf_2p_notch	REG8 (Unused register)
equ	svf_2p_local_lp_state	REG9
equ	svf_2p_local_bp_state	REG10

;	"Generated from spincad source file LPF_RDFX.spincad"
;	"Generated from spincad source file HPF_RDFX.spincad"

; Flattened Execution (TOPOLOGICAL ORDER)
;--------------------------------------------------------------------------------
;===============================================================================
; ADC Input (adc)
; Outputs: Audio: adc_out
; Parameters: ADC Number=0
;-------------------------------------------------------------------------------
;===============================================================================
; 1P LPF (lp1)
; Inputs: Input: adc_out, Frequency: (not connected)
; Outputs: Output: lpf_1p_lpf1
; Parameters: Frequency=1000
;-------------------------------------------------------------------------------
;===============================================================================
; 1P HPF (hp1)
; Inputs: Input: lpf_1p_lpf1, Frequency: (not connected)
; Outputs: Output: hpf_1p_output
; Parameters: Frequency=500
;-------------------------------------------------------------------------------
;===============================================================================
; 2-Pole SVF (svf)
; Inputs: Input: hpf_1p_output, Freq CV: (not connected)
; Outputs: Low Pass: svf_2p_lp
; Parameters: Frequency (Hz)=2000, Resonance (Q)=0.707
;-------------------------------------------------------------------------------
;===============================================================================
; DAC Output (dac)
; Inputs: Audio: svf_2p_lp
; Parameters: DAC Number=0
;-------------------------------------------------------------------------------
rdax	ADCL, 1
; wrax	adc_out, 0
;	variable - Name - low - high - multiplier - precision - option
; rdax	adc_out, 1.0	; rdax not needed with accumulator forwarding optimization
rdfx	lpf_1p_lpf1, 0.174485
; wrax	lpf_1p_lpf1, 0
wrax	lpf_1p_lpf1,	1.0	; Optimization: accumulator forwarded
;	variable - Name - low - high - multiplier - precision - option
; rdax	lpf_1p_lpf1, 1.0	; rdax not needed with accumulator forwarding optimization
rdfx	hpf_1p_local_lpf1, 0.091421
;	do a lowpass filter then subtract that from the lpf_1p_lpf1.
;	voila high pass filter!
rdax	lpf_1p_lpf1, 1.0
; wrax	hpf_1p_output, 0
;	--- 2-Pole SVF (Standard Hal Chamberlin Topology) ---
;	1. Calculate High Pass (H = I - L_old - d * B_old)
;	Fixed Damping (saves register usage & CPU cycles)
; rdax	hpf_1p_output, 1.0	; ACC = I	; rdax not needed with accumulator forwarding optimization
rdax	svf_2p_local_lp_state, -1.0	; ACC = I - L_old
rdax	svf_2p_local_bp_state, -(d_target)	; ACC = I - L_old - d_fixed * B_old = HighPass
;	2. Calculate Band Pass update (B_new = B_old + F * H)
;	High Pass is currently in ACC
sof	cv_b2_f_cv, 0.0	; @mulcv default: frequency
rdax	svf_2p_local_bp_state, 1.0	; ACC = F * H + B_old = B_new
wrax	svf_2p_local_bp_state, 1.0	; REG_B = B_new, ACC = B_new
;	3. Calculate Low Pass update (L_new = L_old + F * B_new)
;	Band Pass is currently in ACC
sof	cv_b2_f_cv, 0.0	; @mulcv default: frequency
rdax	svf_2p_local_lp_state, 1.0	; ACC = F * B_new + L_old = L_new
wrax	svf_2p_lp, 1.0	; EXPORT Low Pass
wrax	svf_2p_local_lp_state, 0.0	; REG_L = L_new, ACC = 0
rdax	svf_2p_lp, 1.0
wrax	DACL, 0