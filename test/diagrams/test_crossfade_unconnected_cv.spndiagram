{
  "version": "1.0",
  "metadata": {
    "name": "test_crossfade_unconnected_cv",
    "author": "",
    "description": "Tests that crossfade2 and crossfade3 compile successfully when the fade control parameters are unconnected."
  },
  "blocks": [
    {
      "id": "input-1",
      "type": "input.adc",
      "position": {
        "x": 0,
        "y": 0
      },
      "parameters": {
        "gain": 1,
        "adcNumber": 0
      }
    },
    {
      "id": "crossfade-2",
      "type": "math.crossfade2",
      "position": {
        "x": 200,
        "y": 0
      },
      "parameters": {
        "fade": 0.5
      }
    },
    {
      "id": "crossfade-3",
      "type": "math.crossfade3",
      "position": {
        "x": 400,
        "y": 0
      },
      "parameters": {
        "fade": 0.5
      }
    },
    {
      "id": "output-1",
      "type": "output.dac",
      "position": {
        "x": 600,
        "y": 0
      },
      "parameters": {
        "dacNumber": 0
      }
    }
  ],
  "connections": [
    {
      "id": "conn_81qtrx4",
      "from": {
        "blockId": "input-1",
        "portId": "out"
      },
      "to": {
        "blockId": "crossfade-2",
        "portId": "input1"
      }
    },
    {
      "id": "conn_3bk1e02",
      "from": {
        "blockId": "input-1",
        "portId": "out"
      },
      "to": {
        "blockId": "crossfade-2",
        "portId": "input2"
      }
    },
    {
      "id": "conn_2sutgzs",
      "from": {
        "blockId": "crossfade-2",
        "portId": "output"
      },
      "to": {
        "blockId": "crossfade-3",
        "portId": "input1"
      }
    },
    {
      "id": "conn_9iqi8ri",
      "from": {
        "blockId": "crossfade-2",
        "portId": "output"
      },
      "to": {
        "blockId": "crossfade-3",
        "portId": "input2"
      }
    },
    {
      "id": "conn_zzj2ulw",
      "from": {
        "blockId": "crossfade-3",
        "portId": "output"
      },
      "to": {
        "blockId": "output-1",
        "portId": "in"
      }
    }
  ],
  "canvas": {
    "zoom": 1,
    "panX": 0,
    "panY": 0
  }
}