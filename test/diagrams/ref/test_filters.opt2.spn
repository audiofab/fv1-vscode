;================================================================================
; test_filters_all
; Tests all filter types (1P LP/HP, Shelving LP/HP, 2P SVF).
;  Block Diagram Editor (https://www.audiofab.com/)
;================================================================================

; Block Declarations
;--------------------------------------------------------------------------------
equ	cv_b2_f_cv	0.374164
equ	cv_b2_q_cv	0.707
;	Calculate resonance range boundaries (negative damping d = -1/Q)
equ	d_low_res -(1.414427)	; Pot=0 (Min Q) -> d_max_damping
equ	d_high_res -(0.050000)	; Pot=1 (Max Q) -> d_min_damping
equ	q_range_scale (d_high_res - d_low_res)

; Initialization
;--------------------------------------------------------------------------------
; Register Aliases
; OPTIMIZED OUT - equ	adc_out	REG0 (Unused register)
equ	lpf_1p_lpf1	REG1
equ	hpf_1p_output	REG2
equ	svf_2p_lp	REG3
; OPTIMIZED OUT - equ	lpf_1p_local_output	REG4 (Unused register)
equ	hpf_1p_local_lpf1	REG5
; OPTIMIZED OUT - equ	svf_2p_bp	REG6 (Unused register)
; OPTIMIZED OUT - equ	svf_2p_hp	REG7 (Unused register)
; OPTIMIZED OUT - equ	svf_2p_notch	REG8 (Unused register)
equ	svf_2p_local_lp_state	REG9
equ	svf_2p_local_bp_state	REG10
; OPTIMIZED OUT - equ	svf_2p_local_temp_lp_new	REG11 (Unused register)
equ	svf_2p_local_temp_inv_lp	REG12
; OPTIMIZED OUT - equ	svf_2p_local_temp_hp	REG13 (Unused register)
equ	svf_2p_local_d_coeff	REG14

;	"Generated from spincad source file LPF_RDFX.spincad"
;	"Generated from spincad source file HPF_RDFX.spincad"

; Flattened Execution (TOPOLOGICAL ORDER)
;--------------------------------------------------------------------------------
;===============================================================================
; ADC Input (adc)
; Outputs: Audio: adc_out
; Parameters: ADC Number=0
;-------------------------------------------------------------------------------
;===============================================================================
; 1P LPF (lp1)
; Inputs: Input: adc_out, Frequency: (not connected)
; Outputs: Output: lpf_1p_lpf1
; Parameters: Frequency=1000
;-------------------------------------------------------------------------------
;===============================================================================
; 1P HPF (hp1)
; Inputs: Input: lpf_1p_lpf1, Frequency: (not connected)
; Outputs: Output: hpf_1p_output
; Parameters: Frequency=500
;-------------------------------------------------------------------------------
;===============================================================================
; 2-Pole SVF (svf)
; Inputs: Input: hpf_1p_output, Freq CV: (not connected), Q CV: (not connected)
; Outputs: Low Pass: svf_2p_lp
; Parameters: Frequency (Hz)=2000, Resonance (Q)=0.707
;-------------------------------------------------------------------------------
;===============================================================================
; DAC Output (dac)
; Inputs: Audio: svf_2p_lp
; Parameters: DAC Number=0
;-------------------------------------------------------------------------------
rdax	ADCL, 1
; wrax	adc_out, 0
;	variable - Name - low - high - multiplier - precision - option
; rdax	adc_out, 1.0	; rdax not needed with accumulator forwarding optimization
rdfx	lpf_1p_lpf1, 0.174485
; wrax	lpf_1p_lpf1, 0
wrax	lpf_1p_lpf1,	1.0	; Optimization: accumulator forwarded
;	variable - Name - low - high - multiplier - precision - option
; rdax	lpf_1p_lpf1, 1.0	; rdax not needed with accumulator forwarding optimization
rdfx	hpf_1p_local_lpf1, 0.091421
;	do a lowpass filter then subtract that from the lpf_1p_lpf1.
;	voila high pass filter!
rdax	lpf_1p_lpf1, 1.0
wrax	hpf_1p_output, 0
;	--- 2-Pole SVF (Fixed Instruction Order & Dynamic Range) ---
;	1. Calculate Low Pass update (L_new = L_old + F * B_old)
rdax	svf_2p_local_bp_state, 1.0	; ACC = BandPass
sof	cv_b2_f_cv, 0.0	; @mulcv default: frequency
rdax	svf_2p_local_lp_state, 1.0	; ACC = F * BandPass + LowPass_old = LowPass_new
wrax	svf_2p_lp, 1.0	; EXPORT Low Pass (ACC remains LowPass_new)
wrax	svf_2p_local_lp_state, -1.0	; REG2 = LowPass_new, ACC = -LowPass_new
wrax	svf_2p_local_temp_inv_lp, 0.0	; REG6 = -LowPass_new, ACC = 0
;	2. Calculate Damping coefficient (Dynamic Negative Mapping)
sof	0.0, cv_b2_q_cv	; CV default: q
sof	q_range_scale, d_low_res	; Map 0..1 to Negative Damping range
wrax	svf_2p_local_d_coeff, 0.0	; REG=d, ACC=0
;	3. Calculate High Pass (H = I - L_new + d * B_old)
rdax	svf_2p_local_bp_state, 1.0	; ACC = BandPass
mulx	svf_2p_local_d_coeff	; ACC = d * BandPass
rdax	svf_2p_local_temp_inv_lp, 1.0	; ACC = d * BandPass - LowPass_new
rdax	hpf_1p_output, 1.0	; ACC = d * BandPass - LowPass_new + Input = H
;	4. Calculate Band Pass update (B_new = B_old + F * H)
sof	cv_b2_f_cv, 0.0	; @mulcv default: frequency
rdax	svf_2p_local_bp_state, 1.0	; ACC = F * H + BandPass_old = BandPass_new
wrax	svf_2p_local_bp_state, 0.0	; REG1 = BandPass_new, ACC = 0
;	5. Notch Calculation (Notch = L_new + H)
rdax	svf_2p_lp, 1.0
wrax	DACL, 0