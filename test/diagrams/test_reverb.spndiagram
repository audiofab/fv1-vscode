{
  "version": "1.0",
  "metadata": {
    "name": "plate_reverb_test",
    "author": "",
    "description": "Tests complex memory allocation, multiple inputs, and internal LFO allocations."
  },
  "blocks": [
    {
      "id": "input-1",
      "type": "input.adc",
      "position": { "x": 0, "y": 0 },
      "parameters": { "gain": 1, "adcNumber": 0 }
    },
    {
      "id": "pot-1",
      "type": "input.pot",
      "position": { "x": 0, "y": 100 },
      "parameters": { "potNumber": 0, "invert": false }
    },
    {
      "id": "pot-2",
      "type": "input.pot",
      "position": { "x": 0, "y": 200 },
      "parameters": { "potNumber": 1, "invert": false }
    },
    {
      "id": "reverb-1",
      "type": "effects.platereverb",
      "position": { "x": 200, "y": 0 },
      "parameters": {
        "size": 0.8,
        "decay": 0.5,
        "damping": 0.5,
        "mix": 0.5
      }
    },
    {
      "id": "output-1",
      "type": "output.dac",
      "position": { "x": 400, "y": 0 },
      "parameters": { "dacNumber": 0 }
    },
    {
      "id": "output-2",
      "type": "output.dac",
      "position": { "x": 400, "y": 100 },
      "parameters": { "dacNumber": 1 }
    }
  ],
  "connections": [
    { "source": "input-1", "sourcePort": "out", "target": "reverb-1", "targetPort": "in" },
    { "source": "pot-1", "sourcePort": "out", "target": "reverb-1", "targetPort": "dampingCV" },
    { "source": "pot-2", "sourcePort": "out", "target": "reverb-1", "targetPort": "decayTimeCV" },
    { "source": "reverb-1", "sourcePort": "outL", "target": "output-1", "targetPort": "in" },
    { "source": "reverb-1", "sourcePort": "outR", "target": "output-2", "targetPort": "in" }
  ]
}
