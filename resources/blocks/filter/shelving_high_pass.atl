---
{
  "type": "fx.filter.shelving_hpf",
  "name": "Shelving HPF",
  "category": "Filter",
  "description": "High-pass filter with adjustable shelf depth",
  "color": "#24f26f",
  "width": 180,
  "inputs": [
    { "id": "in", "name": "Input", "type": "audio", "required": true },
    { "id": "shelf_ctrl", "name": "Shelf", "type": "control", "required": false }
  ],
  "outputs": [
    { "id": "out", "name": "Output", "type": "audio" }
  ],
  "parameters": [
    {
      "id": "frequency",
      "name": "Frequency",
      "type": "number",
      "default": 0.15,
      "min": 0,
      "max": 1,
      "conversion": "LOGFREQ"
    },
    {
      "id": "shelf",
      "name": "Shelf Depth",
      "type": "number",
      "default": -6,
      "min": -40,
      "max": -3,
      "conversion": "DBLEVEL"
    }
  ],
  "registers": ["hpf_state", "temp"]
}
---
; Shelving HPF
rdax ${input.in}, 1.0

@if pinConnected(shelf_ctrl)
; Shelf modulated by control input
@comment "Dynamic shelf control"
wrax ${reg.temp}, -(1.0 - ${shelf})
rdfx ${reg.hpf_state}, ${frequency}
wrlx ${reg.hpf_state}, -1.0
mulx ${input.shelf_ctrl}
rdax ${reg.temp}, 1.0
@else
; Fixed shelf depth
rdfx ${reg.hpf_state}, ${frequency}
wrhx ${reg.hpf_state}, -(1.0 - ${shelf})
@endif

wrax ${output.out}, 0.0
