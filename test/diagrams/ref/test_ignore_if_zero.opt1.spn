;================================================================================
; test_ignore_if_zero
; Tests that ignoreIfZero bypass functionality produces valid assembly for @cv and @mulcv.
;  Block Diagram Editor (https://www.audiofab.com/)
;================================================================================

; Potentiometer Assignments
;--------------------------------------------------------------------------------
; POT0: Pitch Shift (Pitch CV)
; POT1: 2-Pole SVF (Freq CV)

; Block Declarations
;--------------------------------------------------------------------------------
equ	cv_b3_pitch_ctrl	16384.000000
equ	cv_b5_f_cv	0.190575
;	Resonance bounds: Calculate Damping (d = 1/Q)
equ	d_target (1.414427)

; Initialization
;--------------------------------------------------------------------------------
; Register Aliases
equ	adc_out	REG0
equ	pot0_out	REG1
equ	pitch_shift_out	REG2
equ	pot1_out	REG3
equ	svf_2p_lp	REG4
; OPTIMIZED OUT - equ	pot0_local_f1	REG5 (Unused register)
; OPTIMIZED OUT - equ	pot0_local_f2	REG6 (Unused register)
; OPTIMIZED OUT - equ	pot1_local_f1	REG7 (Unused register)
; OPTIMIZED OUT - equ	pot1_local_f2	REG8 (Unused register)
equ	svf_2p_local_lp_state	REG5
equ	svf_2p_local_bp_state	REG6

; Memory Allocations
mem	mem0_buffer	4096
mem	mem1_temp	1

;	Initialize Ramp LFO
skp	run, done_init
wldr	0, 16384.000000, 4096
DONE_INIT:

; Input Section
;--------------------------------------------------------------------------------
rdax	ADCL, 1
wrax	adc_out, 0
ldax	POT0
wrax	pot0_out, 0.0
ldax	POT1
wrax	pot1_out, 0.0

; Main Program
;--------------------------------------------------------------------------------
;	Write input to delay buffer
rdax	adc_out, 1.0
wra	mem0_buffer, 0.0
;	Update pitch shift rate via CV
rdax	pot0_out, 1.0	; Read pot
sof	1.0, -0.02	; Subtract bypass threshold
skp	GEZ, 1	; Skip if pot >= threshold
sof	0.0, 0.480000	; Zero fallback
sof	1.0, 0.02	; Re-add threshold
sof	cv_b3_pitch_ctrl, 0.0	; Scale CV by semitones
wrax	RMP0_RATE, 0.0
;	Perform pitch shift (dual-tap for crossfading)
cho	rda, RMP0, REG | COMPC, mem0_buffer
cho	rda, RMP0, 0, mem0_buffer + 1
wra	mem1_temp, 0.0
cho	rda, RMP0, RPTR2 | COMPC, mem0_buffer
cho	rda, RMP0, RPTR2, mem0_buffer + 1
cho	sof, RMP0, NA | COMPC, 0.0
cho	rda, RMP0, NA, mem1_temp
; wrax	pitch_shift_out, 0.0
wrax	pitch_shift_out,	1.0	; Optimization: accumulator forwarded
;	--- 2-Pole SVF (Standard Hal Chamberlin Topology) ---
;	1. Calculate High Pass (H = I - L_old - d * B_old)
;	Fixed Damping (saves register usage & CPU cycles)
; rdax	pitch_shift_out, 1.0	; ACC = I	; rdax not needed with accumulator forwarding optimization
rdax	svf_2p_local_lp_state, -1.0	; ACC = I - L_old
rdax	svf_2p_local_bp_state, -(d_target)	; ACC = I - L_old - d_fixed * B_old = HighPass
;	2. Calculate Band Pass update (B_new = B_old + F * H)
;	High Pass is currently in ACC
wrax	REG31, 0.0	; Save ACC for @mulcv bypass
rdax	pot1_out, 1.0	; Read pot
sof	1.0, -0.02	; Subtract bypass threshold
skp	GEZ, 1	; Skip if pot >= threshold
sof	0.0, 0.230000	; Zero fallback
sof	1.0, 0.02	; Re-add threshold
mulx	REG31	; Scale saved signal by CV
sof	cv_b5_f_cv, 0.0	; Scale by frequency
rdax	svf_2p_local_bp_state, 1.0	; ACC = F * H + B_old = B_new
wrax	svf_2p_local_bp_state, 1.0	; REG_B = B_new, ACC = B_new
;	3. Calculate Low Pass update (L_new = L_old + F * B_new)
;	Band Pass is currently in ACC
wrax	REG30, 0.0	; Save ACC for @mulcv bypass
rdax	pot1_out, 1.0	; Read pot
sof	1.0, -0.02	; Subtract bypass threshold
skp	GEZ, 1	; Skip if pot >= threshold
sof	0.0, 0.230000	; Zero fallback
sof	1.0, 0.02	; Re-add threshold
mulx	REG30	; Scale saved signal by CV
sof	cv_b5_f_cv, 0.0	; Scale by frequency
rdax	svf_2p_local_lp_state, 1.0	; ACC = F * B_new + L_old = L_new
wrax	svf_2p_lp, 1.0	; EXPORT Low Pass
wrax	svf_2p_local_lp_state, 0.0	; REG_L = L_new, ACC = 0

; Output Section
;--------------------------------------------------------------------------------
;	DAC Output
rdax	svf_2p_lp, 1.0
wrax	DACL, 0