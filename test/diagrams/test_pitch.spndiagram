{
  "version": "1.0",
  "metadata": {
    "name": "test_pitch_modern",
    "description": "Tests all modernized pitch blocks (Octave, Pitch Shift, Pitch Offset) in a single diagram."
  },
  "blocks": [
    {
      "id": "adc",
      "type": "input.adc",
      "position": {
        "x": 0,
        "y": 0
      },
      "parameters": {
        "adcNumber": 0
      }
    },
    {
      "id": "octave",
      "type": "effects.pitch.octave_up_down",
      "position": {
        "x": 150,
        "y": 0
      }
    },
    {
      "id": "shifter",
      "type": "effects.pitch.pitch_shift",
      "position": {
        "x": 350,
        "y": 0
      },
      "parameters": {
        "semitones": 7,
        "bufferSize": 4096
      }
    },
    {
      "id": "offset",
      "type": "effects.pitch.pitch_offset",
      "position": {
        "x": 550,
        "y": 0
      },
      "parameters": {
        "shiftRange": 600,
        "shiftValue": 0.5
      }
    },
    {
      "id": "dac",
      "type": "output.dac",
      "position": {
        "x": 750,
        "y": 0
      },
      "parameters": {
        "dacNumber": 0
      }
    }
  ],
  "connections": [
    {
      "id": "conn_i7nija3",
      "from": {
        "blockId": "adc",
        "portId": "out"
      },
      "to": {
        "blockId": "octave",
        "portId": "in"
      }
    },
    {
